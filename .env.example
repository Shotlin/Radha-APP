# RADHA — Environment variable reference
#
# These are passed to Flutter at build time via --dart-define:
#
#   flutter build apk \
#     --dart-define=RAZORPAY_KEY_ID=rzp_live_xxx \
#     --dart-define=RAZORPAY_MONTHLY_STARTER_PLAN_ID=plan_xxx \
#     ...
#
# For CI: add each variable as a CI secret.
# For local dev: create a .env file (git-ignored) with the real values,
# then source them into your build script.
#
# NEVER commit actual credentials to the repository.

# ── Backend ─────────────────────────────────────────────────────────────────

API_BASE_URL=https://radha.opslin.com

# ── Razorpay ─────────────────────────────────────────────────────────────────
# Public key — safe to include in the app binary.
# The Key Secret must remain server-side only (never put it here).

RAZORPAY_KEY_ID=

# ── Monthly subscription plan IDs (from Razorpay Dashboard → Plans) ──────────

RAZORPAY_MONTHLY_STARTER_PLAN_ID=
RAZORPAY_MONTHLY_GROWTH_PLAN_ID=
RAZORPAY_MONTHLY_GROWTH_PLUS_PLAN_ID=
RAZORPAY_MONTHLY_PREMIUM_PLAN_ID=

# ── 1-Day pass plan IDs ───────────────────────────────────────────────────────

RAZORPAY_DAY_STARTER_PLAN_ID=
RAZORPAY_DAY_GROWTH_PLAN_ID=
RAZORPAY_DAY_PREMIUM_PLAN_ID=
